{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://101.47.12.178:18888/api/$1"
    },
    {
      "source": "/ws/(.*)",
      "destination": "http://101.47.12.178:18888/ws/$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
